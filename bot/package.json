{
  "name": "lina-bot",
  "version": "1.0.0",
  "description": "Bot WhatsApp Lina X — serviço independente",
  "main": "dist/index.js",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "rimraf dist && prisma generate && tsc",
    "build:fast": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "pnpm": {
    "overrides": {
      "libsignal": "https://codeload.github.com/WhiskeySockets/libsignal-node/tar.gz/1c30d7d7e76a3b0aa120b04dc6a26f5a12dccf67"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "9.1.4",
    "@prisma/client": "^6.16.1",
    "@whiskeysockets/baileys": "^6.7.18",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "groq-sdk": "^1.1.2",
    "imapflow": "^1.0.171",
    "mailparser": "^3.7.1",
    "mercadopago": "^2.1.3",
    "pino": "^9.7.0",
    "pix-payload": "^1.0.4",
    "prisma": "^6.16.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@prisma/debug": "6.16.1",
    "@types/express": "^5.0.3",
    "@types/mailparser": "^3.4.5",
    "@types/node": "^24.3.3",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "nodemon": "^3.1.10",
    "qrcode-terminal": "^0.12.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,json",
    "ignore": [
      "prisma/"
    ],
    "exec": "ts-node ./src/index.ts"
  }
}
