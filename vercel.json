{
  "installCommand": "echo \"skip install (static front only)\"",
  "buildCommand": "echo \"no build step\"",
  "outputDirectory": "DESKTOPV2",
  "rewrites": [
    {
      "source": "/p/:token",
      "destination": "/p.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://linacraft.up.railway.app/api/$1"
    }
  ],
  "redirects": [
    { "source": "/data-point-dashboard.html", "destination": "/data-point/", "permanent": false },
    { "source": "/data-point-funcionarios.html", "destination": "/data-point/funcionarios.html", "permanent": false },
    { "source": "/data-point-espelho.html", "destination": "/data-point/espelho.html", "permanent": false },
    { "source": "/data-point-ajustes.html", "destination": "/data-point/ajustes.html", "permanent": false },
    { "source": "/data-point-planos.html", "destination": "/data-point/planos.html", "permanent": false },
    { "source": "/data-point-onboarding.html", "destination": "/data-point/onboarding.html", "permanent": false }
  ]
}
