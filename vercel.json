{
  "installCommand": "echo \"skip install (static front only)\"",
  "buildCommand": "echo \"no build step\"",
  "outputDirectory": "DESKTOPV2",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/p/:token",
      "destination": "/p.html"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://linacraft.up.railway.app/api/$1"
    }
  ],
  "redirects": [
    { "source": "/data-point-dashboard.html", "destination": "/data-point/", "permanent": false },
    { "source": "/data-point-funcionarios.html", "destination": "/data-point/funcionarios.html", "permanent": false },
    { "source": "/data-point-espelho.html", "destination": "/data-point/espelho.html", "permanent": false },
    { "source": "/data-point-ajustes.html", "destination": "/data-point/ajustes.html", "permanent": false },
    { "source": "/data-point-planos.html", "destination": "/data-point/planos.html", "permanent": false },
    { "source": "/data-point-onboarding.html", "destination": "/data-point/onboarding.html", "permanent": false },
    { "source": "/index-funcionario.html", "destination": "/funcionario/", "permanent": false },
    { "source": "/perfil-funcionario.html", "destination": "/funcionario/perfil.html", "permanent": false },
    { "source": "/funcionario/ordens-funcionario.html", "destination": "/funcionario/ordens.html", "permanent": false },
    { "source": "/funcionario/nova-ordem-funcionario.html", "destination": "/funcionario/nova-ordem.html", "permanent": false },
    { "source": "/funcionario/nova-ordem-higienizacao-funcionario.html", "destination": "/funcionario/higienizacao.html", "permanent": false },
    { "source": "/funcionario/fila-entrada-funcionario.html", "destination": "/funcionario/fila-entrada.html", "permanent": false },
    { "source": "/funcionario/clientes-funcionario.html", "destination": "/funcionario/clientes.html", "permanent": false },
    { "source": "/funcionario/funcionarios-funcionario.html", "destination": "/funcionario/equipe.html", "permanent": false },
    { "source": "/funcionario/servicos-funcionario.html", "destination": "/funcionario/servicos.html", "permanent": false },
    { "source": "/funcionario/comissoes-funcionario.html", "destination": "/funcionario/comissoes.html", "permanent": false },
    { "source": "/funcionario/financeiro-funcionario.html", "destination": "/funcionario/financeiro.html", "permanent": false },
    { "source": "/novaordem.html", "destination": "/nova-ordem.html", "permanent": false }
  ]
}
